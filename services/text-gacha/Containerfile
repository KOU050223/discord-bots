# ---- Stage 1: Builder ----
FROM docker.io/library/haskell:9.8.4 AS builder

WORKDIR /build

# 依存関係のみ先にビルド（cabalファイルが変わらない限りキャッシュ再利用）
COPY text-gacha.cabal .
RUN cabal update && cabal build --only-dependencies -j4

# ソースをコピーしてビルド
COPY src/ src/
RUN cabal build exe:text-gacha && \
    cp $(cabal list-bin exe:text-gacha) /text-gacha

# ---- Stage 2: Runtime ----
FROM debian:bookworm-slim AS production

# Haskellランタイムの動的リンクライブラリ
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        libgmp10 \
        zlib1g \
        ca-certificates \
        curl && \
    rm -rf /var/lib/apt/lists/*

# 非rootユーザー
RUN useradd -r -s /bin/false appuser
USER appuser

COPY --from=builder /text-gacha /usr/local/bin/text-gacha

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

CMD ["/usr/local/bin/text-gacha"]
